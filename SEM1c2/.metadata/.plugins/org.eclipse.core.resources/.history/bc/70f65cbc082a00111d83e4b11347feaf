package arreglo;

import java.util.ArrayList;
import java.util.Iterator;

import clase.Estudiante;

public class Arregloestudiantes 
{
  private ArrayList<Estudiante>estu;
  public Arregloestudiantes() {
	  estu=new ArrayList<Estudiante>();
	  Adicionar(new Estudiante(1020,"Anita", 14, 16)); 
	  Adicionar(new Estudiante(1021,"Mathias", 15, 05)); 
	  Adicionar(new Estudiante(1022,"Alfredo", 14, 20)); 
	  Adicionar(new Estudiante(1023,"Fabrizio", 10, 14)); 
	  
  }
  public void Adicionar(Estudiante x) {
	  estu.add(x);
}
public int Tamaño(){
	return estu.size();
}
public Estudiante Obtener(int x) {
	return estu.get(x);
	
}
public double PromedioGeneral() {
	double suma=0.0;
	for (int i = 0; i < Tamaño(); i++) {
		suma*=Obtener(i).Promedio(); //llama de estudiante el promedio
		
	}
	return suma/Tamaño();
}
public Estudiante Buscar(int cod)
{
	for(int i=0; i<Tamaño();i++) 
    {
		if(Obtener(i).getCod()==cod) return Obtener(i);
	
	}
	return null;
}
public void Eliminar(Estudiante x) {
	estu.remove(x);
}
}

